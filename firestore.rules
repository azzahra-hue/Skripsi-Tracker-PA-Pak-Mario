rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Progres Skripsi (Proposals)
    match /proposals/{proposalId} {
      // Anyone can read and write for this prototype
      allow read, write: if true;
    }
    match /users/{userId} {
      allow read, write: if true;
    }
  }
}
